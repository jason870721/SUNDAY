# Binance USDⓈ-M — market data reads MAINNET (public, no key needed);
# trading uses the TESTNET account (keys below). Agents never see these.
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# evva swarm webhook target (Sunday -> swarm): position_pnl + price_alert events
EVVA_WEBHOOK_URL=http://127.0.0.1:8888/api/swarm/sunday/event

# Sunday HTTP server bind
SUNDAY_HOST=127.0.0.1
SUNDAY_PORT=7777

# Local durable state (alerts). No Postgres/Redis — just one sqlite file.
SQLITE_PATH=sunday.db

# Position monitor (req 5): webhook the swarm every N% change in an open position's ROI
MONITOR_ENABLED=true
MONITOR_STEP_PCT=5
MONITOR_POLL_SEC=15

# Realtime price-hub websockets (false → monitor/alerts run on REST polling only)
WS_ENABLED=true
