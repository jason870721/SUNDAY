# Binance USDⓈ-M testnet — needed from T2 (engine adapter); T1 leaves blank
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# PostgreSQL — dedicated DB `sunday` (run once: CREATE DATABASE sunday; docker user/pass=root)
DATABASE_URL=postgresql://root:root@localhost:5432/sunday

# Redis (local docker)
REDIS_URL=redis://localhost:6379/0

# evva swarm webhook target (Sunday -> swarm leader); used from T4
EVVA_WEBHOOK_URL=http://127.0.0.1:8888/api/swarm/sunday/event

# Sunday HTTP server bind
SUNDAY_HOST=127.0.0.1
SUNDAY_PORT=7777
