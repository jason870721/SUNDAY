# Sunday config — copy to engine/.env and fill in. NEVER commit .env (gitignored).
# Every setting has a sane default; only the testnet keys are needed for trading.

# ── Binance ───────────────────────────────────────────────────────────────────
# Market data reads MAINNET (public, no key). Trading uses the TESTNET account
# (keys below); leave blank to run market-data-only — account/perp endpoints then 503.
# Get testnet keys at https://testnet.binancefuture.com (log in → API Key).
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# ── Outbound webhook (Sunday → evva swarm) ────────────────────────────────────
# Where position_pnl + price_alert events POST. Point at any HTTP echo to eyeball them.
EVVA_WEBHOOK_URL=http://127.0.0.1:8888/api/swarm/sunday/event

# ── Telegram notifications (milestone-8, User-facing, optional) ────────────────
# A second outbound channel: reports / price alerts / position PnL → your phone.
# Leave BOTH blank to disable (Sunday behaves identically). Create a bot via @BotFather
# for the token; get your numeric chat id from @userinfobot. Keys stay engine-side —
# never exposed to agents (the proxy still hands agents only HTTP).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── HTTP server ───────────────────────────────────────────────────────────────
SUNDAY_HOST=127.0.0.1
SUNDAY_PORT=7777

# ── Local state ───────────────────────────────────────────────────────────────
# The only durable state is the alerts table — no Postgres/Redis, just one sqlite file.
SQLITE_PATH=sunday.db

# ── Position monitor (req 5) ──────────────────────────────────────────────────
# Webhook the swarm every MONITOR_STEP_PCT% change in an open position's ROI.
MONITOR_ENABLED=true
MONITOR_STEP_PCT=5
MONITOR_POLL_SEC=15          # position-book refresh / REST backstop cadence (seconds)

# ── Realtime price hub (req 5/6) ──────────────────────────────────────────────
# Websocket mark-price streams for the monitor + alerts. false → REST polling only.
WS_ENABLED=true

# ── External indices cache TTLs (seconds, req 4) ──────────────────────────────
INDICES_TTL_FAST=300         # crypto dominance / total market cap (CoinGecko)
INDICES_TTL_MACRO=600        # equities / macro (Stooq + Yahoo fallback)
INDICES_TTL_FEARGREED=3600   # crypto Fear & Greed (alternative.me)
